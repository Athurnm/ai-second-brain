# Vexa auto-join bot credentials (ADVANCED / optional — only for the Vexa bot path).
# The simple local recorder (recorder.py -> transcribe.py -> watcher.py) does NOT need this.
# Copy this file to vexa_token.env and fill in the values from your self-hosted Vexa instance.
# See docs/MEETING_RECORDER.md, section "Advanced: Vexa auto-join bot".
VEXA_API_KEY=your-vexa-api-key-here
VEXA_USER_ID=1
