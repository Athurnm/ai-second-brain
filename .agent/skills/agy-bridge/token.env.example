# Copy this file to `token.env` (same folder) and paste your z.ai GLM Coding Plan token.
# Get it: subscribe at https://z.ai/subscribe -> dashboard -> API key / token.
# Billing is the flat subscription (Lite/Pro/Max), NOT metered per-token.
# token.env is gitignored; this .example file is safe to commit.
ZAI_API_TOKEN=paste-your-zai-coding-plan-token-here
