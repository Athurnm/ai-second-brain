# ============================================================
# Product Second Brain — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env or any token files to version control.
# ============================================================

# === OpenAI (optional, for fallback LLM calls) ===
OPENAI_API_KEY=sk-proj-...

# === Slack ===
# Get from: https://api.slack.com/apps → Your App → OAuth & Permissions
# Required scopes: channels:read, channels:history, chat:write, groups:read,
#                  groups:history, im:read, im:history, users:read, files:read
SLACK_BOT_TOKEN=xoxb-...
SLACK_USER_TOKEN=xoxp-...        # Optional, needed for some user-context reads

# === Fathom (meeting transcripts) ===
# Get from: https://fathom.video/settings/account/integrations
FATHOM_API_KEY=your-fathom-api-key

# === Mixpanel (product analytics) ===
# Get from: https://mixpanel.com → Settings → Project Settings
MIXPANEL_PROJECT_TOKEN=your-project-token
MIXPANEL_PROJECT_ID=your-numeric-project-id
MIXPANEL_API_SECRET=your-api-secret
# Optional: service account credentials (recommended for production)
MIXPANEL_SERVICE_ACCOUNT_USERNAME=
MIXPANEL_SERVICE_ACCOUNT_SECRET=

# === Figma ===
# Get from: https://www.figma.com/settings → Personal Access Tokens
FIGMA_ACCESS_TOKEN=your-figma-pat

# === ClickUp (task management) ===
# Get from: https://app.clickup.com/settings → Apps → API Token
CLICKUP_ACCESS_TOKEN=your-clickup-token

# ============================================================
# Google OAuth tokens are NOT stored here.
# They live as token.json files inside each skill directory
# and are generated automatically on first run.
#
# Required files (generate via first-run OAuth flow):
#   .agent/skills/[your-connector]/credentials.json  ← from Google Cloud Console
#   .agent/skills/[your-connector]/token.json         ← auto-generated on first run
#
# See docs/SETUP.md → "Google OAuth Setup" for full instructions.
# ============================================================
